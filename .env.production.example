# PhishLogic Production Environment Variables
# Copy this file to .env in production and fill in the values

# ============================================================================
# Application
# ============================================================================
NODE_ENV=production
PORT=8080
API_BASE_URL=https://your-service-name.run.app

# ============================================================================
# Database
# ============================================================================
DB_HOST=your-database-host
DB_PORT=5432
DB_NAME=Phishlogic
DB_USER=postgres
DB_PASSWORD=your-secure-database-password
DB_SSL=true

# ============================================================================
# Authentication
# ============================================================================
JWT_SECRET=your-secure-jwt-secret-min-32-characters
JWT_EXPIRES_IN=7d

# SCIM Bearer Token Encryption
SCIM_ENCRYPTION_KEY=your-secure-encryption-key-32-chars

# ============================================================================
# AI Providers (Optional - for AI-powered analysis)
# ============================================================================
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ============================================================================
# External Services
# ============================================================================
# VirusTotal (for URL/file scanning)
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# Google Safe Browsing
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-key

# ============================================================================
# Email Alerts (SMTP)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=phishlogic@your-domain.com

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# CORS (Comma-separated origins)
# ============================================================================
CORS_ORIGIN=https://mail.google.com,chrome-extension://*,https://admin.phishlogic.com

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Security
# ============================================================================
# Set to true only if behind a trusted proxy (Cloud Run, Load Balancer)
TRUST_PROXY=true

# ============================================================================
# Monitoring (Optional)
# ============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=your-sentry-dsn

# Google Cloud Monitoring
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_AI_ANALYSIS=true
ENABLE_SANDBOX_ANALYSIS=true
ENABLE_SCREENSHOT_CAPTURE=true
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# Browser Automation (Playwright)
# ============================================================================
# Set to true to run browsers in headless mode
HEADLESS_BROWSER=true

# Browser timeout (milliseconds)
BROWSER_TIMEOUT=45000
