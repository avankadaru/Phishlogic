# PhishLogic Production Environment Configuration
# Copy this file to prod.env and update values as needed

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=529088285632

# Project Configuration
PROJECT_NAME=phishlogic
ENVIRONMENT=prod

# Terraform Backend (optional - for remote state)
# TF_BACKEND_BUCKET=phishlogic-terraform-state-529088285632
# TF_BACKEND_DYNAMODB_TABLE=phishlogic-terraform-locks
# TF_BACKEND_KEY=prod/terraform.tfstate

# Secrets (auto-generated if not provided)
# JWT_SECRET=
# DB_PASSWORD=
# SCIM_ENCRYPTION_KEY=
# OPENAI_API_KEY=

# Database Configuration
DB_INSTANCE_CLASS=db.t3.small
DB_ALLOCATED_STORAGE=100
DB_NAME=Phishlogic
DB_USERNAME=postgres
DB_MULTI_AZ=true
DB_BACKUP_RETENTION=30

# ECS Configuration
ECS_TASK_CPU=1024
ECS_TASK_MEMORY=2048
ECS_DESIRED_COUNT=2
ECS_MIN_CAPACITY=1
ECS_MAX_CAPACITY=10

# Application Configuration
CONTAINER_PORT=8080
HEALTH_CHECK_PATH=/health
CORS_ORIGINS=chrome-extension://*,https://mail.google.com

# Domain (optional)
# DOMAIN_NAME=phishlogic.example.com
# CREATE_ROUTE53_RECORD=false

# Logging
LOG_LEVEL=INFO
