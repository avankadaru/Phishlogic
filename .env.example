# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phishlogic
DB_USER=phishlogic
DB_PASSWORD=your-secure-password-here
DB_POOL_SIZE=20
DB_SSL=false

# ============================================================================
# Authentication
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=30d

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true

# Analysis Configuration
ANALYSIS_TIMEOUT=30000
STATIC_ANALYSIS_TIMEOUT=10000
DYNAMIC_ANALYSIS_TIMEOUT=25000

# JavaScript Security Scan Timeout (milliseconds)
# Time to wait for runtime script execution events (range: 1000-30000)
SCRIPT_SCAN_TIMEOUT_MS=10000

# Browser Configuration
BROWSER_POOL_SIZE=3
BROWSER_MAX_PAGES=5
BROWSER_TIMEOUT=20000

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Security
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Analysis Thresholds
MALICIOUS_THRESHOLD=0.7
SUSPICIOUS_THRESHOLD=0.4

# ============================================================================
# Analyzer Weights Configuration
# ============================================================================
# Higher weights amplify signal impact on final verdict (range: 0.5-3.0)

# Static Analyzers
ANALYZER_WEIGHT_LINK_REPUTATION=2.5
ANALYZER_WEIGHT_SENDER_REPUTATION=1.8
ANALYZER_WEIGHT_SPF=1.4
ANALYZER_WEIGHT_DKIM=1.4
ANALYZER_WEIGHT_URL_ENTROPY=1.2
ANALYZER_WEIGHT_CONTENT_ANALYSIS=1.6
ANALYZER_WEIGHT_ATTACHMENT=2.3

# Dynamic Analyzers
ANALYZER_WEIGHT_REDIRECT=1.5
ANALYZER_WEIGHT_FORM=1.0

# Email/SMTP Configuration (for alerts)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=phishlogic@example.com
EMAIL_ALERT_RECIPIENTS=security@example.com,admin@example.com
EMAIL_ALERT_THRESHOLD=7
EMAIL_BATCH_MODE=false
EMAIL_BATCH_INTERVAL=3600000

# ============================================================================
# Whitelist Trust Level Configuration
# ============================================================================
# Default trust level for new whitelist entries (high/medium/low)
WHITELIST_DEFAULT_TRUST_LEVEL=high

# Enable/disable trust level feature
WHITELIST_TRUST_LEVEL_ENABLED=true

# Log trust level decisions for audit trail
WHITELIST_TRUST_LEVEL_LOGGING=true

# ============================================================================
# AI Model Configuration
# ============================================================================
# Encryption key for storing AI API keys in database (32+ characters required)
# Generate with: openssl rand -hex 32
AI_MODEL_ENCRYPTION_KEY=change-me-in-production-min-32-characters-required-for-aes-256

# AI execution timeout (milliseconds)
AI_EXECUTION_TIMEOUT_MS=30000

# Hybrid mode: fallback to native analyzers if AI fails (true/false)
AI_HYBRID_FALLBACK_ENABLED=true
