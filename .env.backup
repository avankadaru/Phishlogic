# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Phishlogic
DB_USER=phishlogic
DB_PASSWORD=phishlogic_dev_password
DB_POOL_SIZE=20
DB_SSL=false

# Authentication
JWT_SECRET=phishlogic-dev-jwt-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=30d

# Logging
LOG_LEVEL=info
LOG_PRETTY_PRINT=true

# Analysis Configuration
ANALYSIS_TIMEOUT=30000
STATIC_ANALYSIS_TIMEOUT=10000
DYNAMIC_ANALYSIS_TIMEOUT=25000

# Browser Configuration
BROWSER_POOL_SIZE=3
BROWSER_MAX_PAGES=5
BROWSER_TIMEOUT=20000

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Security
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# SSL/TLS Configuration
# For corporate proxies with self-signed certificates, configure NODE_EXTRA_CA_CERTS
# See docs/development/SSL_CONFIGURATION.md for proper setup
# DO NOT disable certificate validation - use NODE_EXTRA_CA_CERTS instead

# Analysis Thresholds
MALICIOUS_THRESHOLD=0.7
SUSPICIOUS_THRESHOLD=0.4
